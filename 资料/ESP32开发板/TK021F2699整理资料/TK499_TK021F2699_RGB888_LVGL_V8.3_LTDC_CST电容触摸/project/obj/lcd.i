void Lcd_ColorBox(u16 xStart,u16 yStart,u16 xLong,u16 yLong,u32 Color)
{
	u16 i,j;
	u32 temp;
	temp = 480*yStart;
	for(i=0;i<yLong;i++)
	{
		for(j=0;j<xLong;j++)
		LTDC_Buf[xStart+j+480*i+temp]=Color;
	}
}
void Lcd_ColorBox2(u16 xStart,u16 yStart,u16 xLong,u16 yLong,u32 Color)
{
	u16 i,j;
	u32 temp;
	temp = 480*yStart;
	for(i=0;i<yLong;i++)
	{
		for(j=0;j<xLong;j++)
		LTDC_Buf[xStart+j+480*i+temp+800*480]=Color;
	}
}
