void set_resolutionXX(LCD_FORM_TypeDef* LCD_FORM)
{
    u32 aHorStart;
    u32 aHorEnd;
    u32 aVerStart;
    u32 aVerEnd;

    aHorStart = LCD_FORM->blkHorEnd + 1;
    aHorEnd = aHorStart + LCD_FORM->aHorLen;  
    aVerStart = LCD_FORM->blkVerEnd + 1 ;
    aVerEnd = aVerStart + LCD_FORM->aVerLen;

		((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->P_HOR = aHorEnd;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->HSYNC = (LCD_FORM->sHsyncStart <<16 )|LCD_FORM->sHsyncEnd;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->A_HOR = (aHorStart<<16)|aHorEnd;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->A_HOR_LEN = LCD_FORM->aHorLen ;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->BLK_HOR = (0<<16)|LCD_FORM->blkHorEnd;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->P_VER =  aVerEnd;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->VSYNC = (LCD_FORM->sVsyncStart<<16)|LCD_FORM->sVsyncEnd;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->A_VER = (aVerStart<<16)|aVerEnd;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->A_VER_LEN = LCD_FORM->aVerLen ;
		((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->BLK_VER = (0<<16)|LCD_FORM->blkVerEnd;
}


void Set_LCD_Timing_to_LTDC(void)
{
    LCD_FORM_TypeDef LCD_FORM;
	
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->OUT_EN = 0;
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->DP_ADDR0 = (u32)LTDC_Buf;
   ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->DP_ADDR1 = (u32)(LTDC_Buf + 800*480);
    ((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->BLK_DATA = 0x0000;

    LCD_FORM.sHsyncStart = 0x2;  
    LCD_FORM.sHsyncEnd = 0x3;    
    LCD_FORM.aHorLen = 480 - 1;  
    LCD_FORM.blkHorEnd = 0x15;    

    LCD_FORM.sVsyncStart = 0x2;  
    LCD_FORM.sVsyncEnd = 0x3;    
    LCD_FORM.aVerLen= 800 - 1; 	 
    LCD_FORM.blkVerEnd = 0x15;   
	
    set_resolutionXX(&LCD_FORM);

		((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->VI_FORMAT = 0;
		((LTDCTypeDef *) ((((uint32_t)0x40000000) + 0x00020000) + 0x20000))->POL_CTL = 0x3+8;
